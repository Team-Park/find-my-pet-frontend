# API
NEXT_PUBLIC_API_BASE_URL=https://fmp.platformholder.site/api/v1

# Kakao
NEXT_PUBLIC_KAKAO_JS_API_KEY=
NEXT_PUBLIC_AUTH_URL=https://auth.platformholder.site/oauth2/authorization/kakao

# 공공데이터 (동물보호관리시스템 abandonmentPublic)
# 전체 URL에 serviceKey 까지 포함시켜 저장. 뒤에 &pageNo=... 만 추가됨.
NEXT_PUBLIC_API_KEY=http://apis.data.go.kr/1543061/abandonmentPublicSrvc/abandonmentPublic?serviceKey=YOUR_KEY&_type=json&numOfRows=20

# Google (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
